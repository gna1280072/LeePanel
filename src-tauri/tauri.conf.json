{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LeePanel",
  "version": "1.0.7",
  "identifier": "com.leepanel.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LeePanel",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/gna1280072/LeePanel/gh-pages/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1Qjk0MDFCQUFEMDJGNkQKUldSdEw5Q3FHMEM1SmVSNlQ3eEwrNnE0b2RhQ2c4SVdBWFJkMTlaYzdtaWMwdHBNM2xNYXg5cEwK",
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
